# ============================================
# AI Analytics Multi-Agent — Environment
# Phase 1: Native Windows + Fabric DW
# Copy:  copy .env.example .env
# ============================================

# ─────────────────────────────────────────────
# Microsoft Fabric Data Warehouse
# ─────────────────────────────────────────────
# FABRIC_SERVER: SQL analytics endpoint จาก Fabric Portal
# FABRIC_DATABASE: ชื่อ warehouse (Phase 1 = WH_SAP_PRD)
# FABRIC_TENANT_ID / CLIENT_ID / CLIENT_SECRET: Service Principal (Entra ID)

FABRIC_SERVER=your-workspace.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=WH_SAP_PRD
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_ODBC_DRIVER=ODBC Driver 18 for SQL Server
FABRIC_CONNECTION_TIMEOUT=30
# FABRIC_QUERY_TIMEOUT: จำกัดเวลารัน query ต่อครั้ง (วินาที) — กัน query หนักค้างไม่จบ
FABRIC_QUERY_TIMEOUT=300
FABRIC_MAX_ROWS=100
# FABRIC_ROW_COUNT_THRESHOLD: pre-flight COUNT(*) — reject ถ้าประมาณแถวเกินเกณฑ์ (Phase D)
FABRIC_ROW_COUNT_THRESHOLD=50000
# FABRIC_SQL_ENABLED: false = ข้าม live SQL ทั้งหมด (ใช้ตอน capacity pause / offline Explore)
FABRIC_SQL_ENABLED=true
# TTL จำผล ping ล้มเหลว (วินาที) — กัน timeout ซ้ำทุก query
FABRIC_REACHABILITY_TTL_SECONDS=300

# ─────────────────────────────────────────────
# PostgreSQL WH_Silver mirror (auto-fallback)
# ─────────────────────────────────────────────
# ข้อมูลเดียวกับ Fabric ทุกอย่าง (migrate/mirror มาไว้ที่ Postgres) — ใช้เป็น
# ทางเลือกสำรองอัตโนมัติเมื่อ Fabric unreachable/paused โดยไม่ต้องปรับ config
# เพิ่ม: DA agent จะสลับสร้าง SQL ให้ตรง dialect (T-SQL ↔ PostgreSQL) ให้เอง
# เว้นว่างทั้งหมด = ปิดใช้งาน (ระบบจะข้าม SQL เหมือนเดิมตอน Fabric ลง)
PG_REPLICA_HOST=
PG_REPLICA_PORT=5432
PG_REPLICA_DB=fabric_WH_Silver
PG_REPLICA_USER=
PG_REPLICA_PASSWORD=
PG_REPLICA_CONNECT_TIMEOUT=10
PG_REPLICA_QUERY_TIMEOUT=300

# ─────────────────────────────────────────────
# Ollama — Model recommendations
# ─────────────────────────────────────────────
# | Use case              | Model                    | VRAM/RAM hint |
# |-----------------------|--------------------------|---------------|
# | Phase 1 default ★     | qwen2.5-coder:14b        | ~10–12 GB     |
# | Deep insight (Level D)| qwen2.5-coder:32b        | ~20–24 GB     |
# | Thai business text    | qwen2.5:14b-instruct     | ~10 GB        |
# | SQL-focused alt       | deepseek-coder-v2:16b    | ~12 GB        |
#
# Pull: .\scripts\setup-ollama-models.ps1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_MODEL_ANALYST=
OLLAMA_MODEL_BA=
OLLAMA_TIMEOUT=600
# OLLAMA_NUM_CTX: context window (tokens) — 16384 กัน context ถูกตัดเงียบ; ลดเป็น 8192 ถ้า VRAM ไม่พอ
OLLAMA_NUM_CTX=16384
# OLLAMA_NUM_PREDICT: จำกัดความยาวคำตอบ (default 1024 — สำคัญมากบนเครื่อง CPU-only:
# ถ้าไม่จำกัด agent จะ generate ได้หลายพัน token ที่ ~5 tok/s จนงานชน wall clock)
OLLAMA_NUM_PREDICT=1024
# OLLAMA_KEEP_ALIVE: ให้โมเดลค้างใน RAM ระหว่าง step (default ของ Ollama คือ 5m
# ทำให้ต้อง reload โมเดล ~90s ก่อนทุก step) — 60m ครอบคลุมทั้ง pipeline
OLLAMA_KEEP_ALIVE=60m

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
LOG_LEVEL=INFO
STREAMLIT_PORT=8501
BACKEND_URL=http://127.0.0.1:8000
# CHAT_JOB_MAX_SECONDS: wall-clock cap เฉพาะส่วน graph ของงาน chat (agent pipeline + SQL retry)
# — ขั้น consultant review ถูก bound แยกต่างหากด้วย CONSULTANT_TIMEOUT + 30s (Phase D)
CHAT_JOB_MAX_SECONDS=1200
# ONBOARDING_JOB_MAX_SECONDS: wall-clock cap ทั้งงาน onboarding (DE→DA→DS→BA + coach)
# — ตั้งเผื่อไว้มาก เพราะแต่ละ role เรียก Ollama ได้นานถึง OLLAMA_TIMEOUT ต่อครั้ง
ONBOARDING_JOB_MAX_SECONDS=3600
# หมายเหตุ: งาน consult (ถามที่ปรึกษา) ถูก bound ด้วย CONSULTANT_TIMEOUT + 30s อัตโนมัติ ไม่มี setting แยก
# Frontend HTTP client timeouts (Streamlit) — FRONTEND_HTTP_TIMEOUT เปลี่ยนชื่อจาก
# COMPOSE_HTTP_TIMEOUT เดิม (ชื่อเก่ายังใช้ได้เป็น fallback)
FRONTEND_HTTP_TIMEOUT=600
CHAT_HTTP_TIMEOUT=3600
ONBOARDING_HTTP_TIMEOUT=3600

# ─────────────────────────────────────────────
# Local storage
# ─────────────────────────────────────────────
DATA_LOCAL_DIR=data/local
DATA_TEMPLATES_DIR=data/templates

# Phase G2 — inject approved Metric Registry formulas into Data Analyst prompt
METRIC_REGISTRY_IN_PROMPT=true

# Phase H — analytics engine (snapshots + detectors)
# Wall-clock cap for snapshot_refresh job (backfill 36 months can be slow)
SNAPSHOT_REFRESH_MAX_SECONDS=900
# Inject computed detector summary into Data Scientist prompt when snapshots exist
ANALYTICS_CONTEXT_IN_PROMPT=true

# ─────────────────────────────────────────────
# Phase I — proactive insights (default off)
# ─────────────────────────────────────────────
INSIGHT_PIPELINE_ENABLED=false
INSIGHT_CRON_HOUR=2
INSIGHT_NARRATE_TOP_K=8
INSIGHT_CATCHUP_AFTER_HOURS=24
INSIGHT_PIPELINE_MAX_SECONDS=1800

# ─────────────────────────────────────────────
# Phase J — learning loops
# ─────────────────────────────────────────────
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_CONTEXT_ENABLED=false
SQL_PATTERN_CONTEXT_ENABLED=false
SQL_LESSONS_IN_PROMPT=true

# ─────────────────────────────────────────────
# Phase K — board digest + curriculum study
# ─────────────────────────────────────────────
DIGEST_ENABLED=false
DIGEST_AFTER_PIPELINE=true
DIGEST_CRON_HOUR=6
CONSULTANT_POLISH_DIGEST=false
STUDY_ENABLED=false
STUDY_CRON_HOUR=3
STUDY_QUESTIONS_PER_RUN=2
STUDY_THEME_ID=sales
STUDY_JOB_MAX_SECONDS=3600

# ─────────────────────────────────────────────
# Claude External Consultant (Anthropic)
# ─────────────────────────────────────────────
# ที่ปรึกษาภายนอกระดับโลก — ไม่แทนที่ทีม Local (DE/DA/DS/BA)
# เปิดใช้เมื่อมี API key และ CONSULTANT_ENABLED=true
# โมเดล: claude-opus-4-8 ≈ $5/$25 ต่อ MTok (~$0.15–0.35 ต่อ call)
# Data Security: ส่งเฉพาะ schema + aggregate — ห้าม row-level ออกนอกเครื่อง
#
# โหมด (เปิด/ปิดแยกได้):
#   CONSULTANT_REVIEW_CHAT      — รีวิวคำตอบก่อนส่ง CEO
#   CONSULTANT_COACH_ONBOARDING — โค้ชทีมหลัง onboarding
#   CONSULTANT_ON_DEMAND        — ถามที่ปรึกษาเองจาก UI
#   CONSULTANT_HELP_WHEN_STUCK  — ช่วยเมื่อ pipeline ติดขัด

ANTHROPIC_API_KEY=
CONSULTANT_ENABLED=false
CONSULTANT_MODEL=claude-opus-4-8
CONSULTANT_MAX_TOKENS=16000
CONSULTANT_TIMEOUT=300
CONSULTANT_MAX_SECTION_CHARS=6000
CONSULTANT_REVIEW_CHAT=true
CONSULTANT_COACH_ONBOARDING=true
CONSULTANT_ON_DEMAND=true
CONSULTANT_HELP_WHEN_STUCK=true

# ─────────────────────────────────────────────
# PostgreSQL (legacy — not used Phase 1 runtime)
# ─────────────────────────────────────────────
POSTGRES_USER=analytics_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=analytics_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
